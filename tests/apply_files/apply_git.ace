def path(p):
    return "/dev/" + p if config("_dev", False) else p

app(path("/applytest/test1"), "github.com/openrundev/apps/system/disk_usage", stage_at="path")
app(path("/applytest/test2"), "github.com/openrundev/apps/system/memory_usage", stage_at="path")
app(path("/applytest/test3"), "github.com/openrundev/apps/system/list_files", stage_at="path")
